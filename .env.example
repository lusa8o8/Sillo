# Database Configuration
DATABASE_URL="postgresql://postgres.project-ref:encoded-password@aws-region.pooler.supabase.com:5432/postgres?sslmode=require"
PGHOST="aws-region.pooler.supabase.com"
PGUSER="postgres.project-ref"
PGPASSWORD=""
PGDATABASE="postgres"
PGPORT="5432"

# Temporary local user used as the dev fallback when Firebase Admin is not configured
DEV_USER_ID="user-123"

# --- Firebase Admin (server-side token verification) ---
# Provide ONE of the following. A full service account is recommended.
# 1. Full service account JSON, stringified onto a single line:
FIREBASE_SERVICE_ACCOUNT=""
# 2. Or a path to a service account key file:
GOOGLE_APPLICATION_CREDENTIALS=""
# 3. Or just the project id (sufficient to verify ID tokens):
FIREBASE_PROJECT_ID="sillo-42acd"

# YouTube API (Optional - falls back to mock data if not set)
YOUTUBE_API_KEY="your_youtube_api_key_here"

# Session Secret (Generate a random string)
SESSION_SECRET="generate_a_random_secret_here"

# AI provider: groq | cerebras | gemini
AI_PROVIDER="groq"
AI_MODEL=""
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
CEREBRAS_API_KEY=""
CEREBRAS_MODEL="llama-3.3-70b"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash-exp"

# --- AI limits & gating ---
# Max output tokens per AI call (applies to all providers).
AI_MAX_OUTPUT_TOKENS="900"
# Reject any single input field longer than this many characters.
AI_MAX_INPUT_CHARS="4000"
# Token-budget rate limit, per user, per rolling window.
AI_RATE_LIMIT_WINDOW_MS="60000"
AI_RATE_LIMIT_MAX_REQUESTS="20"
AI_RATE_LIMIT_MAX_TOKENS="20000"
# Gate AI features behind a paid plan. When "true", only the allowlisted user
# ids may use AI endpoints; everyone else gets HTTP 402. Replace the allowlist
# with a real subscription/entitlement lookup once billing is wired in.
AI_GATING_ENABLED="false"
AI_ALLOWLIST_USER_IDS=""

# Supabase API
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY=""
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Environment
NODE_ENV="development"

# Client API URL (for Vite)
VITE_API_URL=""
